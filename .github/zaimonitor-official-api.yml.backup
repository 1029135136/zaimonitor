name: ZAI Inference Monitor (Official API)

on:
#   push:
#     branches:
#       - main
#     paths:
#       - script/**

  schedule:
    - cron: "10 */2 * * *"   # at :10 every 2 hours (UTC)

  workflow_dispatch:

concurrency:
  group: zaimonitor-official-api
  cancel-in-progress: false

jobs:
  monitor_official_api:
    runs-on: ubuntu-latest
    timeout-minutes: 30

    defaults:
      run:
        working-directory: script

    steps:
      - name: Checkout repo
        uses: actions/checkout@v4

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install -r requirements.txt

      - name: Run monitor (official_api endpoint, both models)
        run: |
          set +e
          failures=0
          for model in glm-5 glm-4.7; do
            echo "::group::official_api / ${model}"
            ZAI_BASE_URL="https://api.z.ai/api/paas/v4" \
            ZAI_MODEL="${model}" \
            ZAI_ENDPOINT_FAMILY="official_api" \
            python monitor_zai_inference.py
            status=$?
            echo "::endgroup::"
            if [ "${status}" -ne 0 ]; then
              failures=1
              echo "Run failed for official_api/${model} with exit code ${status}"
            fi
          done
          exit "${failures}"
        env:
          # Required
          ZAI_API_KEY: ${{ secrets.ZAI_API_KEY_OFFICIAL_API }}
          MONGODB_URI: ${{ secrets.MONGODB_URI }}
          AUTO_LOAD_DOTENV: "false"
