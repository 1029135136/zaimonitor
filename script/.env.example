# Required
ZAI_API_KEY=...
ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4
ZAI_MODEL=
MONGODB_URI=

# Optional (defaults shown)
MONGO_DB=
MONGO_COLLECTION=
CONNECT_TIMEOUT_SECONDS=15
STREAM_READ_TIMEOUT_SECONDS=600
# Legacy fallback still supported by the script:
# HTTP_TIMEOUT_SECONDS=600
REQUEST_RETRIES=2
REQUEST_RETRY_BACKOFF_SECONDS=1.5
LOG_PROGRESS=true

# Optional dotenv loader behavior
AUTO_LOAD_DOTENV=true
ENV_FILE=.env